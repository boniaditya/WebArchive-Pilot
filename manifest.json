{
  "manifest_version": 3,
  "name": "WebArchive Pilot",
  "version": "1.1.0",
  "description": "Save any webpage as a .webarchive file and open .webarchive files directly in Chrome.",
  "permissions": ["activeTab", "downloads", "pageCapture", "tabs", "contextMenus", "notifications", "storage"],
  "host_permissions": ["file:///*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
